# ===========================================
# Yellow Box Markets Chatbot - Configuration
# ===========================================
# Copy this file to .env and fill in your keys

# --- AI Provider (Gemini) ---
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash

# --- YBX CRM (Live prices, analysis, calendar) ---
CRM_API_URL=https://api.yellowboxmarkets.com
CRM_BOT_EMAIL=your_bot_account_email
CRM_BOT_PASSWORD=your_bot_account_password

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# --- Discord Bot ---
DISCORD_BOT_TOKEN=MTIzNDU2Nzg5MDEyMzQ1Njc4OQ.XXXXXX.XXXXXXXXXXXXXXXXXXXXXXXXXX
DISCORD_APP_ID=1234567890123456789

# --- LINE Bot ---
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
LINE_CHANNEL_SECRET=your_line_channel_secret

# --- Telegram Mini App ---
WEBAPP_URL=https://your-domain.example.com/webapp/

# --- Deposit Payment Info (fallbacks if CRM doesn't return them) ---
DEPOSIT_PROMPTPAY_QR_URL=
DEPOSIT_PROMPTPAY_ID=
DEPOSIT_USDT_WALLET=
DEPOSIT_USDT_NETWORK=TRC-20
DEPOSIT_BANK_NAME=
DEPOSIT_BANK_ACCOUNT=
DEPOSIT_BANK_ACCOUNT_NAME=

# --- Security ---
SESSION_TOKEN_SECRET=your_session_token_secret_here
ADMIN_API_KEY=your_admin_api_key_here

# --- Database ---
DATABASE_URL=postgresql://user:password@host:5432/dbname

# --- Telegram Polling ---
TELEGRAM_POLLING_ENABLED=true

# --- Webhooks & External APIs ---
WEBHOOK_BASE_URL=https://your-domain.com
TRADINGVIEW_WEBHOOK_SECRET=your_webhook_secret_here
FINNHUB_API_KEY=your_finnhub_api_key_here

# --- Server ---
PORT=3000
NODE_ENV=development
